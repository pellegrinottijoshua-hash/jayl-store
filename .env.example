# ── Stripe ────────────────────────────────────────────────────────────────────
# Frontend (publishable key — safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Backend only — NEVER expose to the client
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Gelato ────────────────────────────────────────────────────────────────────
# Server-side only — never expose to the client (no VITE_ prefix)
GELATO_API_KEY=...

# ── CORS allow-list (optional) ───────────────────────────────────────────────
# Set to your production origin. Vercel preview URLs (*.vercel.app) and
# localhost are auto-allowed.
SITE_URL=https://jayl.store
