# ── Stripe ────────────────────────────────────────────────────────────────────
# Frontend (publishable key — safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Backend only — NEVER expose to the client
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Gelato ────────────────────────────────────────────────────────────────────
# Used in both Vercel API routes and (if needed) client-side product fetching
VITE_GELATO_API_KEY=...
